---
interface Props {
  value: number;
  label?: boolean;
}

const { value, label = true } = Astro.props;
const rounded = Math.round(value);
const stars = Array.from({ length: 5 }, (_, index) => index < rounded);
---

<span class="rating" aria-label={`${value} no 5`}>
  <span class="stars" aria-hidden="true">
    {stars.map((filled) => <span class={filled ? "" : "star-muted"}>★</span>)}
  </span>
  {label && <span>{value.toFixed(1)}</span>}
</span>
