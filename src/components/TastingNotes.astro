---
import { getCriteriaAverage, type EvaluationCriteria } from "../data/reviewRating";

interface Props {
  notes: EvaluationCriteria;
}

const { notes } = Astro.props;
const averageRating = getCriteriaAverage(notes);
const rows = [
  ["Garša", notes.taste],
  ["Sāls", notes.salt],
  ["Tekstūra", notes.texture],
  ["Eļļa / marināde", notes.oil],
  ["Cena / kvalitāte", notes.priceQuality],
] as const;
---

<div class="criteria-summary">
  <span>Vidējais vērtējums</span>
  <strong>{averageRating.toFixed(1)}</strong>
</div>

<div class="note-grid">
  {
    rows.map(([label, criterion]) => (
      <div class="note">
        <div class="note-top">
          <span>{label}</span>
          <span class="note-score">{criterion.score.toFixed(1)}</span>
        </div>
        <p>{criterion.note}</p>
      </div>
    ))
  }
  <div class="note">
    <div class="note-top">
      <span>Kopējais spriedums</span>
    </div>
    <p>{notes.verdict}</p>
  </div>
</div>
