---
interface Props {
  notes: {
    smoke: number;
    salt: number;
    texture: number;
    acidity: number;
  };
}

const { notes } = Astro.props;
const rows = [
  ["Dūmainums", notes.smoke],
  ["Sāļums", notes.salt],
  ["Tekstura", notes.texture],
  ["Skābums", notes.acidity],
] as const;
---

<div class="note-grid">
  {
    rows.map(([label, value]) => (
      <div class="note">
        <div class="note-top">
          <span>{label}</span>
          <span>{value}/5</span>
        </div>
        <div class="note-bar" aria-hidden="true">
          <span style={`width: ${(value / 5) * 100}%`}></span>
        </div>
      </div>
    ))
  }
</div>
