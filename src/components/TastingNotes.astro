---
interface Props {
  notes: {
    taste: string;
    salt: string;
    texture: string;
    oil: string;
    priceQuality: string;
    verdict: string;
  };
}

const { notes } = Astro.props;
const rows = [
  ["Garša", notes.taste],
  ["Sāls", notes.salt],
  ["Tekstūra", notes.texture],
  ["Eļļa / marināde", notes.oil],
  ["Cena / kvalitāte", notes.priceQuality],
  ["Kopējais spriedums", notes.verdict],
] as const;
---

<div class="note-grid">
  {
    rows.map(([label, value]) => (
      <div class="note">
        <div class="note-top">
          <span>{label}</span>
        </div>
        <p>{value}</p>
      </div>
    ))
  }
</div>
