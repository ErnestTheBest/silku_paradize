---
interface Props {
  current?: "home" | "reviews";
}

const { current = "home" } = Astro.props;
const base = import.meta.env.BASE_URL;
const links = [
  { href: base, label: "Sākums", key: "home" },
  { href: `${base}reviews/`, label: "Apskati", key: "reviews" },
] as const;
---

<header class="site-header">
  <div class="page-shell header-inner">
    <a class="brand" href={base} aria-label="Siļķu Paradīze sākumlapa">
      <span class="brand-mark">S</span>
      <span>Siļķu Paradīze</span>
    </a>
    <nav class="nav-links" aria-label="Galvenā navigācija">
      {
        links.map((link) => (
          <a class:list={["nav-link", current === link.key && "is-active"]} href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <button class="menu-button" type="button" aria-label="Pārslēgt izvēlni" data-menu-toggle>
      <span aria-hidden="true">☰</span>
    </button>
  </div>
</header>

<script>
  const button = document.querySelector("[data-menu-toggle]");
  button?.addEventListener("click", () => {
    document.body.classList.toggle("menu-open");
  });
</script>
