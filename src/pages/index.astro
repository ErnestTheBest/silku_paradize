---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ReviewCard from "@components/ReviewCard.astro";
import heroImage from "../assets/site/hero.jpg";
import missionImage from "../assets/site/mission.jpg";
import meImage from "../assets/people/ernests.jpg";
import notMeImage from "../assets/people/alisa.jpg";

const allReviews = (await getCollection("reviews")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const reviews = allReviews.slice(0, 3);
const brandCount = new Set(allReviews.map((review) => review.data.brand)).size;

const base = import.meta.env.BASE_URL;
const experienceStart = new Date(2026, 4, 1);
const today = new Date();
const yearsExperience = Math.max(
  0,
  today.getFullYear() -
    experienceStart.getFullYear() -
    (today.getMonth() < experienceStart.getMonth() ||
    (today.getMonth() === experienceStart.getMonth() &&
      today.getDate() < experienceStart.getDate())
      ? 1
      : 0),
);
---

<BaseLayout
  title="Siļķu Paradīze"
  description="Rūpīgi veidots Baltijas siļķu apskatu arhīvs."
  current="home"
>
  <main>
    <section class="hero" style={`--hero-image: url('${heroImage.src}')`}>
      <div class="page-shell hero-content">
        <p class="eyebrow">Baltijas apskatu arhīvs</p>
        <h1>Siļķu Paradīze</h1>
        <p>
          Lai neviena siļķe netiktu aizmirsta. Mēs glabājam atmiņu.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={`${base}reviews/`}>Skatīt apskatus</a>
        </div>
      </div>
    </section>

    <section class="section page-shell" id="mission">
      <div class="mission-grid">
        <div class="panel panel-pad">
          <p class="eyebrow">Mūsu misija</p>
          <h2>Atcerēties, kuru siļķi jau esam ēduši, un saglabāt šīs zināšanas.</h2>
          <p>
            Ik pa laikam pie siļķu plaukta Maxima vai kādā citā Latvijas veikalā nonākam
            vienā un tajā pašā situācijā — burciņu daudz, bet vairs nav skaidrs, kuras jau
            esam nogaršojuši. Tāpēc šeit pierakstām savus iespaidus: kas jau nogaršots, kas
            patika un pie kurām siļķēm gribētos atgriezties vēlreiz.
          </p>
          <div class="metric-row" aria-label="Vietnes galvenie rādītāji">
            <div class="metric">
              <strong>{allReviews.length}</strong>
              <span>Apskati</span>
            </div>
            <div class="metric">
              <strong>{yearsExperience}</strong>
              <span>Gadu pieredze</span>
            </div>
            <div class="metric">
              <strong>{brandCount}</strong>
              <span>Zīmoli</span>
            </div>
          </div>
        </div>
        <div class="panel image-panel">
          <img
            src={missionImage.src}
            alt="Ernests pie siļķu pierakstiem"
          />
        </div>
      </div>
    </section>

    <section class="curators-section section">
      <div class="page-shell">
        <div class="section-heading centered-heading">
          <p class="eyebrow">Komanda</p>
          <h2>Iepazīsties ar pašpasludinātajiem siļķu ekspertiem</h2>
          <p>
            Cilvēki aiz apskatiem: garšas, tekstūras un aukstā galda tradīciju mednieki,
            kuri meklē godīgas siļķes ikdienas un svētku galdam.
          </p>
        </div>

        <div class="curator-grid">
          <article class="curator-card">
            <div class="curator-image">
              <img
                src={meImage.src}
                alt="Ernests Pakers"
                loading="lazy"
              />
            </div>
            <div class="curator-body">
              <h3>Ernests Pakers</h3>
              <p class="curator-role">Aizmāršīgais kritiķis</p>
              <p>
                Tas pats cilvēks, kurš aizmirst, kuru siļķi viņš jau ir nogaršojis.
              </p>
            </div>
          </article>

          <article class="curator-card">
            <div class="curator-image">
              <img
                src={notMeImage.src}
                alt="Alisa Zurmitai"
                loading="lazy"
              />
            </div>
            <div class="curator-body">
              <h3>Alisa Zurmitai</h3>
              <p class="curator-role">Smējās par vietnes nosaukumu</p>
              <p>
                Viņa teica, ka tā ir lieliska ideja, un to atbalstīja.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section-tight page-shell">
      <div class="section-heading">
        <p class="eyebrow">Jaunākie pieraksti</p>
        <h2>Svaigi no apskatu plaukta</h2>
        <p>
          Šīs kartītes tiek veidotas no Markdown ierakstiem. Pievieno jaunu failu
          <code>src/content/reviews</code>, un tas parādīsies pēc nākamās izbuves.
        </p>
      </div>
      <div class="review-grid">
        {reviews.map((review) => <ReviewCard review={review} />)}
      </div>
    </section>
  </main>
</BaseLayout>
